          "name": "Create Sparring Request",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Token {{token}}" }
            ],
            "url": "{{base_url}}/api/sparring/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"opponent_id\": 2,\n  \"gym_id\": 1,\n  \"proposed_date\": \"2024-01-20\",\n  \"proposed_time\": \"18:00\",\n  \"message\": \"Let's keep it technical, no big shots\"\n}"
