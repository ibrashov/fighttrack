    },
    {
      "name": "Sparring",
      "item": [
        {
          "name": "List All My Sparring Requests",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Token {{token}}" }],
            "url": "{{base_url}}/api/sparring/"
          },
          "response": [
            {
              "name": "200 OK",
              "code": 200,
              "body": "[\n  {\n    \"id\": 1,\n    \"initiator\": 1,\n    \"initiator_username\": \"fighter1\",\n    \"opponent\": 2,\n    \"opponent_username\": \"fighter2\",\n    \"gym\": 1,\n    \"gym_detail\": { \"id\": 1, \"name\": \"Nomad Fight Club\", \"city\": \"Almaty\" },\n    \"proposed_date\": \"2024-01-20\",\n    \"proposed_time\": \"18:00:00\",\n    \"message\": \"Let's keep it technical, no big shots\",\n    \"status\": \"pending\",\n    \"status_display\": \"Pending\",\n    \"created_at\": \"2024-01-15T10:00:00Z\",\n    \"updated_at\": \"2024-01-15T10:00:00Z\"\n  }\n]"
