          ]
        },
        {
          "name": "Incoming Sparring Requests",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Token {{token}}" }],
            "url": "{{base_url}}/api/sparring/incoming/"
          },
          "response": [
            { "name": "200 OK", "code": 200, "body": "[ { \"id\": 1, \"initiator_username\": \"fighter1\", \"status\": \"pending\" } ]" }
          ]
        },
        {
          "name": "Accept / Decline Request",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Token {{token}}" }
            ],
            "url": "{{base_url}}/api/sparring/1/status/",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"accepted\"\n}"
            }
          },
          "response": [
            { "name": "200 OK", "code": 200, "body": "{ \"id\": 1, \"status\": \"accepted\", \"status_display\": \"Accepted\" }" }
          ]
        },
        {
          "name": "Cancel Sparring Request",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Token {{token}}" }],
            "url": "{{base_url}}/api/sparring/1/"
          },
          "response": [
            { "name": "200 OK", "code": 200, "body": "{ \"id\": 1, \"status\": \"cancelled\" }" }
